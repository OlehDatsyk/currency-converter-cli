# -----------------------------------------------------------------------
# Currency Converter CLI - Environment Variables
# -----------------------------------------------------------------------
# 1. Copy this file and rename the copy to ".env"
# 2. Fill in your real API key below
# 3. Never commit your real ".env" file to Git (it is already ignored)
# -----------------------------------------------------------------------

# Your personal API key from https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_api_key_here

# Base URL for the exchange rate provider (usually no need to change this)
EXCHANGE_RATE_API_BASE_URL=https://v6.exchangerate-api.com/v6

# Maximum seconds to wait for the API before treating it as a network error
REQUEST_TIMEOUT_SECONDS=10
